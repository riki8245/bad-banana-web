---
// Footer component - Contains contact info and social links
---

<footer class="bg-gray-900 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand Info -->
      <div>
        <h3 class="text-2xl font-bold mb-4">
            <span class="inline-flex items-center gap-2 ">
                <img src="/bad-banana-web/badBananaLogo.png" alt="BadBanana Logo" class="w-12 h-12">
                <span>Bad Banana</span>
            </span>
        </h3>
        <p class="text-gray-400">
          <span class="lang" data-lang="en">Handmade pet portraits on wood. Each piece is unique and crafted with love and passion 💛</span>
          <span class="lang hidden" data-lang="es">Retratos de mascotas hechos a mano en madera. Cada pieza es única y elaborada con amor y pasión 💛</span>
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-bold text-lg mb-4">
          <span class="lang" data-lang="en">Quick Links</span>
          <span class="lang hidden" data-lang="es">Enlaces Rápidos</span>
        </h4>
        <ul class="space-y-2 text-gray-400">
          <li>
            <a href="/" class="hover:text-white transition">
              <span class="lang" data-lang="en">Home</span>
              <span class="lang hidden" data-lang="es">Inicio</span>
            </a>
          </li>
          <li>
            <a href="#gallery" class="hover:text-white transition">
              <span class="lang" data-lang="en">Gallery</span>
              <span class="lang hidden" data-lang="es">Galería</span>
            </a>
          </li>
          <li>
            <a href="#about" class="hover:text-white transition">
              <span class="lang" data-lang="en">About</span>
              <span class="lang hidden" data-lang="es">Acerca de</span>
            </a>
          </li>
          <li>
            <a href="#contact" class="hover:text-white transition">
              <span class="lang" data-lang="en">Contact</span>
              <span class="lang hidden" data-lang="es">Contacto</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-bold text-lg mb-4">
          <span class="lang" data-lang="en">Contact</span>
          <span class="lang hidden" data-lang="es">Contacto</span>
        </h4>
        <ul class="space-y-2 text-gray-400">
          <li>
            📧 <a href="mailto:annaddiaz@hotmail.com" class="hover:text-white transition">annaddiaz@hotmail.com</a>
          </li>
          <li>
            📍 Instagram: <a href="https://www.instagram.com/badbanana.shop" target="_blank" class="hover:text-white transition">@badbanana.shop</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-700 pt-2 text-center">
      <span class="lang" data-lang="en">&copy; 2026 Bad Banana. All rights reserved. Made with 🍌</span>
      <span class="lang hidden" data-lang="es">&copy; 2026 Bad Banana. Todos los derechos reservados. Hecho con 🍌</span>
    </div>
  </div>
</footer>